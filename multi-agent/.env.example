# Claude API Configuration
CLAUDE_API_KEY=sk-ant-api03-xxxxxxxxxxxxx

# Model Configuration
# Main agent model - používá se pro hlavní orchestraci a koordinaci
MAIN_AGENT_MODEL=claude-opus-4-1-20250805

# Subagent model - používá se pro paralelní subagenty analyzující části dokumentu
SUBAGENT_MODEL=claude-3-5-haiku-20241022

# Dostupné modely (leden 2025):
# === NEJNOVĚJŠÍ MODELY ===
# claude-opus-4-1-20250805
# claude-sonnet-4-20250514
# claude-3-5-haiku-20241022

#
# === CENY (za milion tokenů) ===
# Haiku 3.5:  $0.80 vstup / $4 výstup
# Sonnet 3.5: $3 vstup / $15 výstup
# Opus 3.0:   $15 vstup / $75 výstup

# Performance Configuration
MAX_PARALLEL_AGENTS=10        # Maximální počet paralelních subagentů
CHUNK_SIZE=50000              # Velikost chunků pro dělení dokumentu (v znacích)

# Timeout Configuration (v sekundách)
AGENT_TIMEOUT=120             # Timeout pro jednotlivé agenty
QUERY_TIMEOUT=60              # Timeout pro jednotlivé dotazy

# Debug Configuration
DEBUG_MODE=false              # Zapne debug výpisy
VERBOSE_LOGGING=false         # Detailní logování

# Tokenizers Configuration
TOKENIZERS_PARALLELISM=false  # Vypne parallelism warning z huggingface tokenizers

# Cache Configuration
ENABLE_CACHE=true             # Zapne cachování výsledků
CACHE_DIR=.cache              # Adresář pro cache

# Prompt Configuration
PROMPTS_DIR=prompts           # Adresář s prompt templates
CUSTOM_SYSTEM_PROMPT=         # Vlastní systémový prompt (volitelné)