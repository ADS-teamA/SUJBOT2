# Production Environment Variables
# Copy this file to .env.prod and fill in your actual values
# IMPORTANT: Keep this file secure and never commit actual .env.prod to git

# General
ENVIRONMENT=production
DEBUG=false
SECRET_KEY=CHANGE-THIS-TO-A-SECURE-RANDOM-STRING-IN-PRODUCTION

# Claude API
CLAUDE_API_KEY=your-production-claude-api-key-here

# Redis
REDIS_PASSWORD=CHANGE-THIS-TO-A-SECURE-REDIS-PASSWORD
REDIS_URL=redis://:CHANGE-THIS-TO-A-SECURE-REDIS-PASSWORD@redis:6379/0

# Celery
CELERY_BROKER_URL=redis://:CHANGE-THIS-TO-A-SECURE-REDIS-PASSWORD@redis:6379/0
CELERY_RESULT_BACKEND=redis://:CHANGE-THIS-TO-A-SECURE-REDIS-PASSWORD@redis:6379/1

# Frontend URLs (production domain)
VITE_API_URL=https://sujbot2.example.com/api/v1
VITE_WS_URL=wss://sujbot2.example.com/ws

# File storage
MAX_UPLOAD_SIZE=524288000  # 500 MB
UPLOAD_DIR=/app/uploads
INDEX_DIR=/app/indexes

# Security
CORS_ORIGINS=["https://sujbot2.example.com"]

# Logging
LOG_LEVEL=INFO
VERBOSE_LOGGING=false
