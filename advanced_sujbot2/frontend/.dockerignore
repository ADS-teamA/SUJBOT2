# Frontend .dockerignore
# Exclude unnecessary files from Docker build context

# Dependencies
node_modules/

# Build output
dist/
build/

# Testing
coverage/
.nyc_output/

# Cache
.cache/
.parcel-cache/
.vite/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Git
.git/
.gitignore

# Documentation
*.md
docs/

# Environment files
.env
.env.*

# OS files
.DS_Store
Thumbs.db

# Docker
Dockerfile*
docker-compose*.yml
.dockerignore

# Misc
*.zip
*.tar.gz
