# Backend .dockerignore
# Exclude unnecessary files from Docker build context

# Python cache
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# Virtual environments
venv/
env/
ENV/
.venv

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Testing
.pytest_cache/
.coverage
htmlcov/
.tox/

# Logs
*.log
logs/

# Data directories (will be mounted as volumes)
uploads/
indexes/

# Git
.git/
.gitignore

# Documentation
*.md
docs/

# Environment files
.env
.env.*

# OS files
.DS_Store
Thumbs.db

# Docker
Dockerfile*
docker-compose*.yml
.dockerignore
